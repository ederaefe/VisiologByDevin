# ==============================================================================
# VISIOLOG Environment Variables
# ==============================================================================

# 1. Google Gemini AI (Vision Extraction)
# Get from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 2. Supabase (Database & Authentication)
# Get from: https://supabase.com/dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 3. Cloudinary (Image Hosting)
# Get from: https://cloudinary.com/console -> Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# 4. Stripe (Optional - For Tier 2 Billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
